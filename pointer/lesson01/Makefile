# --------------------------------------------------------
# C/C++ 自動判別・コンパイル＆実行用 Makefile
# --------------------------------------------------------

# ターゲットを指定せずに `make` のみを実行した場合のヘルプ表示
.PHONY: all
all:
	@echo "【使い方】"
	@echo "  make [ファイル名（拡張子なし）]"
	@echo ""
	@echo "【実行例】"
	@echo "  main.c または main.cpp をコンパイルして実行したい場合:"
	@echo "  make main"

# C言語用のルール (.c ファイルが存在する場合に自動選択されます)
%: %.c
	@echo "=== C言語を検出しました (gcc でコンパイル中...) ==="
	gcc -o $*.out $<
	@echo "=== 実行結果 ==="
	./$*.out

# C++用のルール (.cpp ファイルが存在する場合に自動選択されます)
%: %.cpp
	@echo "=== C++言語を検出しました (g++ でコンパイル中...) ==="
	g++ -o $*.out $<
	@echo "=== 実行結果 ==="
	./$*.out

# 生成された .out ファイルをすべて削除するクリーンアップ機能
# 使い方: make clean
.PHONY: clean
clean:
	rm -f *.out
